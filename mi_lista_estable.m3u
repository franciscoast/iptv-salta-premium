import subprocess
import os

def obtener_url_m3u8(url_web_oficial):
    comando = ['python', '-m', 'yt_dlp', '--socket-timeout', '10', '-g', url_web_oficial]
    try:
        resultado = subprocess.run(comando, capture_output=True, text=True, timeout=15)
        return resultado.stdout.strip() if resultado.returncode == 0 else None
    except: return None

# 1. CANALES DINÁMICOS (Se actualizan por YouTube)
canales_dinamicos = {
    "1. TV Publica": "https://www.youtube.com/watch?v=O130_N-f_7I",
    "2. Telefe": "https://www.youtube.com/@telefe/live",
    "3. DeporTV": "https://www.youtube.com/@canaldeportv/live",
    "4. TN Todo Noticias": "https://www.youtube.com/@todonoticias/live"
}

# 2. CANALES DIRECTOS (Google DAI y Premium - Los más estables)
canales_estaticos = {
    "5. AMERICA TV (Google HD)": "https://dai.google.com/linear/hls/pa/event/OY2i_lL4SMyXE5Zaj4ULEg/stream/882ee0f7-fa43-499c-b598-5102a8076cff:SCL2/master.m3u8",
    "6. A24 (Google HD)": "https://dai.google.com/linear/hls/pa/event/Txk1vDlZR2CCfDuUZ0ylpw/stream/3f52902a-22c2-4163-8438-ab9e4413b732:SCL2/master.m3u8",
    "7. ESPN Premium": "http://dplatino.net:80//live/credito3geotv/car26octtv/149087.ts",
    "8. TyC Sports": "http://dplatino.net:80//live/credito3geotv/car26octtv/81252.ts",
    "9. TNT Sports": "http://dplatino.net:80//live/credito3geotv/car26octtv/81284.ts",
    "10. FOX Sports": "http://dplatino.net:80//live/credito3geotv/car26octtv/50506.ts",
    "11. Pluto TV Deportes": "http://samsung-ar.pluto.tv/samsung-ar/linear/6082e0fb521c70000787e6fa/master.m3u8"
}

ruta_archivo = os.path.join(os.path.dirname(os.path.abspath(__file__)), "mi_lista_estable.m3u")

with open(ruta_archivo, "w") as f:
    f.write("#EXTM3U\n")
    for nom, url in canales_dinamicos.items():
        link = obtener_url_m3u8(url)
        if link: f.write(f"#EXTINF:-1,{nom}\n{link}\n")
    for nom, url in canales_estaticos.items():
        f.write(f"#EXTINF:-1,{nom}\n{url}\n")

print("¡LISTO! Archivo generado con todos los canales.")
